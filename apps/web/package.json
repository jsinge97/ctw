{
  "name": "@ctw/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "node server.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts",
    "lint": "eslint src",
    "e2e": "pnpm run e2e:api && pnpm run e2e:browser",
    "e2e:api": "vitest run --config vitest.e2e.config.ts",
    "e2e:browser": "pnpm --dir ../.. build && pnpm --dir ../.. exec playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@ctw/api-client": "workspace:*",
    "@ctw/contracts": "workspace:*",
    "@ctw/domain": "workspace:*",
    "@ctw/permissions": "workspace:*",
    "react-dropzone": "^15.0.0"
  }
}
